// 天天象棋自动签到插件 v1.0
// 根据实际抓包记录生成
// 使用方法：在LOON中安装后，每天自动执行或手动运行

const $ = $substore;

// 调试模式，设置为false关闭日志
const DEBUG = true;

function log(...args) {
    if (DEBUG) {
        console.log(`[天天象棋]`, ...args);
    }
}

// API配置
const API_CONFIG = {
    host: "szextshort.weixin.qq.com",
    baseHeaders: {
        "Accept": "*/*",
        "Cache-Control": "no-cache",
        "Connection": "Keep-Alive",
        "Content-Type": "application/octet-stream",
        "Host": "szextshort.weixin.qq.com",
        "Upgrade": "mmtls",
        "User-Agent": "MicroMessenger Client"
    }
};

// 签到请求配置
const CHECKIN_REQUESTS = [
    {
        id: 1,
        name: "签到请求1",
        method: "POST",
        path: "/mmtls/4e3f9f89",
        bodyBase64: "",
        description: "请求体大小: 609字节, 时间戳: 1775869609241"
    },
    {
        id: 2,
        name: "签到请求2",
        method: "POST",
        path: "/mmtls/4e4a64ef",
        bodyBase64: "",
        description: "请求体大小: 609字节, 时间戳: 1775869651662"
    },
    {
        id: 3,
        name: "签到请求3",
        method: "POST",
        path: "/mmtls/4e48995e",
        bodyBase64: "",
        description: "请求体大小: 620字节, 时间戳: 1775869644283"
    },
    {
        id: 4,
        name: "签到请求4",
        method: "POST",
        path: "/mmtls/4e535ec4",
        bodyBase64: "",
        description: "请求体大小: 620字节, 时间戳: 1775869686675"
    },
    {
        id: 5,
        name: "签到请求5",
        method: "POST",
        path: "/mmtls/4e71a1be",
        bodyBase64: "",
        description: "请求体大小: 703字节, 时间戳: 1775869804392"
    },
    {
        id: 6,
        name: "签到请求6",
        method: "POST",
        path: "/mmtls/4e732ba8",
        bodyBase64: "",
        description: "请求体大小: 703字节, 时间戳: 1775869810160"
    },
];

// Base64解码函数（兼容LOON环境）
function decodeBase64(base64Str) {
    try {
        // 方法1: 使用atob（浏览器环境）
        if (typeof atob !== 'undefined') {
            const binaryStr = atob(base64Str);
            const bytes = new Uint8Array(binaryStr.length);
            for (let i = 0; i < binaryStr.length; i++) {
                bytes[i] = binaryStr.charCodeAt(i);
            }
            return bytes.buffer;
        }
        
        // 方法2: 使用Buffer（Node.js环境）
        if (typeof Buffer !== 'undefined') {
            return Buffer.from(base64Str, 'base64');
        }
        
        // 方法3: 直接返回字符串（备用）
        log("无法解码Base64，使用原始字符串");
        return base64Str;
    } catch (error) {
        log(`Base64解码失败: ${error}`);
        return base64Str;
    }
}

// 执行单个请求
async function executeRequest(requestConfig) {
    try {
        const url = `https://${API_CONFIG.host}${requestConfig.path}`;
        
        log(`执行请求: ${requestConfig.name}`);
        log(`URL: ${url}`);
        log(`方法: ${requestConfig.method}`);
        
        const headers = { ...API_CONFIG.baseHeaders };
        
        // 准备请求选项
        const options = {
            url: url,
            method: requestConfig.method,
            headers: headers,
            timeout: 15000
        };
        
        // 处理请求体
        if (requestConfig.bodyBase64) {
            try {
                const bodyBytes = decodeBase64(requestConfig.bodyBase64);
                if (bodyBytes instanceof ArrayBuffer || bodyBytes instanceof Uint8Array) {
                    // 对于二进制数据，使用bodyBytes
                    options.bodyBytes = bodyBytes;
                } else {
                    // 备用方案：直接使用base64字符串
                    options.body = requestConfig.bodyBase64;
                }
                log(`请求体大小: ${requestConfig.bodyBase64.length}字符（Base64）`);
            } catch (error) {
                log(`请求体处理失败: ${error}`);
                options.body = requestConfig.bodyBase64;
            }
        }
        
        const startTime = Date.now();
        const response = await $.http.request(options);
        const elapsedTime = Date.now() - startTime;
        
        log(`请求完成，状态码: ${response.statusCode}, 耗时: ${elapsedTime}ms`);
        
        // 检查响应
        if (response.statusCode >= 200 && response.statusCode < 300) {
            log(`请求成功`);
            
            // 尝试分析响应
            if (response.body && response.body.length > 0) {
                log(`响应长度: ${response.body.length}字节`);
                
                // 如果是文本响应，尝试显示部分内容
                if (typeof response.body === 'string') {
                    const preview = response.body.substring(0, 200);
                    log(`响应预览: ${preview}...`);
                }
            }
            
            return {
                success: true,
                statusCode: response.statusCode,
                elapsedTime: elapsedTime
            };
        } else {
            log(`请求失败，状态码: ${response.statusCode}`);
            return {
                success: false,
                statusCode: response.statusCode,
                elapsedTime: elapsedTime
            };
        }
        
    } catch (error) {
        log(`请求异常: ${error}`);
        return {
            success: false,
            error: String(error)
        };
    }
}

// 执行所有签到请求
async function executeAllCheckins() {
    log("开始执行天天象棋签到流程");
    log(`总共 ${CHECKIN_REQUESTS.length} 个请求需要执行`);
    
    const results = [];
    let successCount = 0;
    let failCount = 0;
    
    for (let i = 0; i < CHECKIN_REQUESTS.length; i++) {
        const requestConfig = CHECKIN_REQUESTS[i];
        
        log(`\n[${i + 1}/${CHECKIN_REQUESTS.length}] 执行: ${requestConfig.name}`);
        
        const result = await executeRequest(requestConfig);
        results.push(result);
        
        if (result.success) {
            successCount++;
        } else {
            failCount++;
        }
        
        // 请求之间延迟，模拟真实操作
        if (i < CHECKIN_REQUESTS.length - 1) {
            log(`等待1秒后执行下一个请求...`);
            await $.wait(1000);
        }
    }
    
    log(`\n签到流程完成`);
    log(`成功: ${successCount}, 失败: ${failCount}, 总计: ${CHECKIN_REQUESTS.length}`);
    
    return {
        results: results,
        successCount: successCount,
        failCount: failCount,
        total: CHECKIN_REQUESTS.length
    };
}

// 主函数
async function main() {
    log("=== 天天象棋自动签到插件 ===");
    
    const startTime = Date.now();
    const result = await executeAllCheckins();
    const totalTime = Date.now() - startTime;
    
    log(`\n总执行时间: ${totalTime}ms`);
    
    // 生成通知
    const title = "天天象棋签到";
    let subtitle = `完成 ${result.successCount}/${result.total}`;
    let message = `执行时间: ${totalTime}ms\n`;
    
    if (result.failCount === 0) {
        subtitle = "签到成功";
        message += `所有请求执行成功！`;
    } else if (result.successCount > 0) {
        subtitle = `部分成功 (${result.successCount}/${result.total})`;
        message += `${result.successCount}个成功, ${result.failCount}个失败`;
    } else {
        subtitle = "签到失败";
        message += `所有请求都失败了，请检查网络或配置`;
    }
    
    message += `\n\n详细日志请查看LOON日志面板`;
    
    // 发送通知
    $.msg(title, subtitle, message);
    
    return result;
}

// LOON插件接口
if (typeof $argument !== "undefined") {
    // 通过参数触发（手动执行）
    main().then(result => {
        $done({});
    }).catch(error => {
        log(`插件执行错误: ${error}`);
        $.msg("天天象棋签到", "执行错误", String(error));
        $done({});
    });
} else {
    // 通过定时任务触发
    exports.cron = "0 9 * * *"; // 每天上午9点执行
    exports.handler = main;
}

// 导出函数供其他脚本调用
exports.executeCheckin = main;
